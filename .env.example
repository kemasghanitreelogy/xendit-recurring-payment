# ========== Xendit ==========
# JANGAN isi nilai sebenarnya di file ini — file ini di-commit ke git.
# Nilai sebenarnya disimpan di .env.local (gitignored).
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=
XENDIT_API_URL=https://api.xendit.co

# ========== Supabase (DB only — no Auth) ==========
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ========== Shopify ==========
# my-store.myshopify.com (no protocol, no trailing slash)
SHOPIFY_STORE_DOMAIN=
# Admin API access token (Custom App), scopes: write_customers, read_customers, write_orders, read_orders
SHOPIFY_ADMIN_TOKEN=
# Shared secret dari Custom App — untuk verifikasi App Proxy HMAC
SHOPIFY_APP_PROXY_SECRET=
# Pin API version supaya tidak ke-break diam-diam saat Shopify update
SHOPIFY_API_VERSION=2024-10

# ========== App ==========
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ========== Admin reconciliation ==========
# Random long string, generate dengan: openssl rand -hex 32
ADMIN_RECONCILE_TOKEN=

# ========== Vercel Cron (production only) ==========
# Used by /api/admin/reconcile/cron. Either:
#   (a) leave empty in local dev — the cron route returns 503, OR
#   (b) set the same value here AND in Vercel project env so the cron job
#       (configured in vercel.json) can authenticate. Vercel can auto-inject
#       this if you generate it in the Vercel dashboard.
# Generate: openssl rand -hex 32
CRON_SECRET=

# ========== Alerting (optional but recommended for production) ==========
# Slack/Discord-compatible incoming webhook URL. When set, the backend posts
# alerts here on: webhook handler crashes, Shopify order sync failures, and
# reconcile runs that finish with unresolved backlog.
# Slack:   https://hooks.slack.com/services/T.../B.../...
# Discord: https://discord.com/api/webhooks/.../...
ALERT_WEBHOOK_URL=

# ========== Xendit webhook IP allowlist (optional, recommended) ==========
# Comma-separated list of IPs Xendit sends webhooks from. When set, the
# webhook endpoint rejects any other source IP with 403 — defense-in-depth
# on top of the x-callback-token check.
# Get current IPs from Xendit dashboard / support.
XENDIT_WEBHOOK_IPS=
